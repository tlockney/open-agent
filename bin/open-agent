#!/usr/bin/env bash
# open-agent — CLI for managing the open-agent remote development toolkit
#
# Subcommands:
#   setup-remote <host|all>   Deploy scripts to remote host(s)
#   update                    Fetch and install latest release from GitHub
#   status                    Query the local daemon status
#   version                   Print version
#   help                      Show this help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_OWNER="tlockney"
REPO_NAME="open-agent"
VERSION="0.2.0"

source "$SCRIPT_DIR/lib/open-agent.sh"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
fail()  { echo -e "${RED}✗${NC} $1" >&2; exit 1; }
step()  { echo -e "${BLUE}→${NC} $1"; }

OA_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/open-agent"
HOSTS_FILE="$OA_CONFIG_DIR/remote-hosts"
LEGACY_HOSTS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/rproj/hosts"

# --- Helpers ---

# Load unique hosts from remote-hosts config (field 1, pipe-delimited)
load_host_aliases() {
    local hosts_file="$HOSTS_FILE"
    if [[ ! -f "$hosts_file" ]]; then
        if [[ -f "$LEGACY_HOSTS_FILE" ]]; then
            hosts_file="$LEGACY_HOSTS_FILE"
            warn "Using legacy hosts file at $hosts_file"
        else
            fail "No hosts file found at $HOSTS_FILE\nCreate it with format: host_alias|project_dir|label"
        fi
    fi

    local -a seen=()
    while IFS='|' read -r alias _rest; do
        [[ -z "$alias" || "$alias" == \#* ]] && continue
        alias="${alias## }" ; alias="${alias%% }"
        # Deduplicate
        local already=false
        for s in "${seen[@]+"${seen[@]}"}"; do
            [[ "$s" == "$alias" ]] && { already=true; break; }
        done
        $already && continue
        seen+=("$alias")
        echo "$alias"
    done < "$hosts_file"
}

# Build a tarball of scripts to deploy to remotes
build_deploy_tarball() {
    local tmpfile
    tmpfile=$(mktemp /tmp/open-agent-deploy.XXXXXX.tar.gz)

    # Determine where open-agent-hook.sh lives relative to bin/
    local hook_path="$SCRIPT_DIR/../open-agent-hook.sh"
    if [[ ! -f "$hook_path" ]]; then
        # Installed layout: hook is in ~/.local/share/open-agent/
        hook_path="$HOME/.local/share/open-agent/open-agent-hook.sh"
    fi
    [[ -f "$hook_path" ]] || fail "Cannot find open-agent-hook.sh"

    local tmpdir
    tmpdir=$(mktemp -d)

    # Copy bin scripts
    mkdir -p "$tmpdir/bin/lib"
    for script in ropen rcode rcopy rpaste rnotify rop rpush rpull; do
        if [[ -f "$SCRIPT_DIR/$script" ]]; then
            cp "$SCRIPT_DIR/$script" "$tmpdir/bin/"
        fi
    done
    cp "$SCRIPT_DIR/lib/open-agent.sh" "$tmpdir/bin/lib/"

    # Copy hook
    cp "$hook_path" "$tmpdir/open-agent-hook.sh"

    tar -czf "$tmpfile" -C "$tmpdir" .
    rm -rf "$tmpdir"
    echo "$tmpfile"
}

# --- Commands ---

cmd_setup_remote() {
    local target="${1:-}"
    [[ -z "$target" ]] && fail "Usage: open-agent setup-remote <host|all>"

    local -a hosts=()
    if [[ "$target" == "all" ]]; then
        while IFS= read -r h; do
            hosts+=("$h")
        done < <(load_host_aliases)
        [[ ${#hosts[@]} -eq 0 ]] && fail "No hosts found in config"
        step "Deploying to ${#hosts[@]} host(s): ${hosts[*]}"
    else
        hosts=("$target")
    fi

    # Build tarball once
    step "Building deploy package..."
    local tarball
    tarball=$(build_deploy_tarball)

    local failed=0
    for host in "${hosts[@]}"; do
        echo ""
        step "Deploying to $host..."

        # Validate SSH connectivity
        if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$host" "true" 2>/dev/null; then
            warn "Cannot connect to $host (skipping)"
            failed=$((failed + 1))
            continue
        fi

        # Deploy: extract to ~/.local/bin/ and ~/.local/share/open-agent/
        ssh "$host" "mkdir -p ~/.local/bin/lib ~/.local/share/open-agent" && \
        cat "$tarball" | ssh "$host" "
            set -e
            cd \$(mktemp -d)
            tar xzf -
            cp bin/* ~/.local/bin/
            cp bin/lib/* ~/.local/bin/lib/
            cp open-agent-hook.sh ~/.local/share/open-agent/
            chmod +x ~/.local/bin/r* ~/.local/bin/lib/open-agent.sh
        " && info "$host: deployed successfully" || {
            warn "$host: deployment failed"
            failed=$((failed + 1))
        }
    done

    rm -f "$tarball"

    echo ""
    if [[ $failed -eq 0 ]]; then
        info "All hosts deployed successfully"
    else
        warn "$failed host(s) failed"
    fi

    echo ""
    echo "Post-deploy steps on each remote host:"
    echo "  1. Ensure ~/.local/bin is in PATH:"
    echo "     export PATH=\"\$HOME/.local/bin:\$PATH\""
    echo ""
    echo "  2. Source the hook in ~/.zshrc (or ~/.bashrc):"
    echo "     source ~/.local/share/open-agent/open-agent-hook.sh"
    echo ""
    echo "  3. Reconnect SSH to activate the forwarded socket."
}

cmd_update() {
    step "Checking for latest release..."

    local latest_tag
    latest_tag=$(curl -fsSL "https://api.github.com/repos/$REPO_OWNER/$REPO_NAME/releases/latest" \
        | grep '"tag_name"' | head -1 | sed 's/.*"tag_name": *"//;s/".*//')

    if [[ -z "$latest_tag" ]]; then
        fail "Could not fetch latest release from GitHub"
    fi

    step "Latest release: $latest_tag"

    local tmpdir
    tmpdir=$(mktemp -d)
    local tarball_url="https://github.com/$REPO_OWNER/$REPO_NAME/releases/download/$latest_tag/${REPO_NAME}-${latest_tag}.tar.gz"

    step "Downloading $tarball_url..."
    if ! curl -fsSL "$tarball_url" -o "$tmpdir/release.tar.gz"; then
        rm -rf "$tmpdir"
        fail "Failed to download release tarball"
    fi

    step "Extracting..."
    tar xzf "$tmpdir/release.tar.gz" -C "$tmpdir"

    # Find the extracted directory (should be open-agent-vX.Y.Z/)
    local extracted
    extracted=$(find "$tmpdir" -maxdepth 1 -type d -name "${REPO_NAME}-*" | head -1)
    if [[ -z "$extracted" ]]; then
        # Might have extracted without prefix
        extracted="$tmpdir"
    fi

    step "Installing..."
    if [[ -f "$extracted/install.sh" ]]; then
        bash "$extracted/install.sh" --local
    else
        fail "install.sh not found in release tarball"
    fi

    rm -rf "$tmpdir"
    info "Update complete"
}

cmd_status() {
    oa_init "${HOME}/.local/share/open-agent/open-agent.sock"

    if [[ ! -S "$OA_SOCK" ]]; then
        echo -e "${RED}Agent is not running${NC} (no socket at $OA_SOCK)"
        echo ""
        echo "Start it with: launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.open-agent.daemon.plist"
        exit 1
    fi

    local response
    response=$(oa_send '{"action":"status"}') || {
        fail "Failed to connect to agent socket"
    }

    echo "$response" | python3 -c '
import json, sys
d = json.load(sys.stdin)
print(f"Agent: running")
sessions = d.get("sessions", {})
mounts = d.get("mounts", {})
print(f"Sessions: {len(sessions)} active")
for host, sids in sessions.items():
    count = len(sids) if isinstance(sids, list) else sids
    print(f"  {host}: {count} session(s)")
print(f"Mounts: {len(mounts)} active")
for host, info in mounts.items():
    mount_path = info if isinstance(info, str) else info.get("path", "unknown")
    print(f"  {host}: {mount_path}")
' 2>/dev/null || echo "$response"
}

cmd_version() {
    echo "open-agent $VERSION"
}

show_help() {
    cat <<EOF
Usage: open-agent <command> [args]

Commands:
    setup-remote <host|all>   Deploy r* scripts and hook to remote host(s)
    update                    Fetch and install latest release from GitHub
    status                    Query the local daemon status
    version                   Print version
    help                      Show this help

Config:
    Hosts file: $HOSTS_FILE
    Format: host_alias|project_dir|label (one per line)

Examples:
    open-agent setup-remote workmbp     # Deploy to a single host
    open-agent setup-remote all         # Deploy to all configured hosts
    open-agent status                   # Check daemon status
    open-agent update                   # Update to latest release
EOF
    exit 0
}

# --- Main ---

[[ $# -eq 0 ]] && show_help

command="$1"
shift

case "$command" in
    setup-remote) cmd_setup_remote "$@" ;;
    update)       cmd_update "$@" ;;
    status)       cmd_status "$@" ;;
    version)      cmd_version ;;
    help|--help|-h) show_help ;;
    *) fail "Unknown command: $command. See 'open-agent help'" ;;
esac
